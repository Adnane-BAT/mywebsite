#!/bin/bash

# =====================================================
# PARAMETRES
# =====================================================

SOURCE="/mnt/bpce-res/data/DRG/Controle_permanent_des_risques/15. Projets/Outil WF 2.2/Output/"
DESTINATION="/mnt/bpce-res/data/DRG/Controle_permanent_des_risques/15. Projets/Outil WF 2.2/"

LOGDIR="/var/log/WorkflowControlePermanent"

# =====================================================
# CREATION DOSSIER LOG
# =====================================================

mkdir -p "$LOGDIR"

# =====================================================
# DATE DU JOUR POUR NOM DU LOG
# =====================================================

DATETIME=$(date +"%Y%m%d_%H%M%S")
LOGFILE="$LOGDIR/Workflow_$DATETIME.log"

{
echo "====================================================="
echo "DEBUT EXECUTION : $(date '+%Y-%m-%d %H:%M:%S')"
echo "====================================================="
echo ""
echo "Source      : $SOURCE"
echo "Destination : $DESTINATION"
echo ""
} >> "$LOGFILE"

echo "=========================================="
echo "Debut synchronisation"
echo "=========================================="

# =====================================================
# CONTROLES
# =====================================================

if [ ! -d "$SOURCE" ]; then
    echo "ERREUR : dossier source introuvable : $SOURCE" | tee -a "$LOGFILE"
    exit 10
fi

if [ ! -d "$DESTINATION" ]; then
    echo "Creation du dossier destination : $DESTINATION" | tee -a "$LOGFILE"
    mkdir -p "$DESTINATION"
fi

# =====================================================
# COPIE INCREMENTALE
# Equivalent Robocopy :
# /E   => -a + copie recursive
# /XO  => --update : ne remplace pas les fichiers plus recents
# /FFT => --modify-window=2
# /Z   => --partial
# /R:3 /W:5 => retry via boucle
# /NP  => --no-progress
# =====================================================

MAX_RETRY=3
WAIT_SECONDS=5
TRY=1

while [ $TRY -le $MAX_RETRY ]; do

    echo "" | tee -a "$LOGFILE"
    echo "Tentative $TRY / $MAX_RETRY" | tee -a "$LOGFILE"

    rsync -av \
        --update \
        --recursive \
        --modify-window=2 \
        --partial \
        --no-progress \
        "$SOURCE" \
        "$DESTINATION" \
        >> "$LOGFILE" 2>&1

    RC=$?

    if [ $RC -eq 0 ]; then
        echo "" | tee -a "$LOGFILE"
        echo "Synchronisation terminee avec succes" | tee -a "$LOGFILE"
        echo "Code retour rsync : $RC" >> "$LOGFILE"

        echo "=========================================="
        echo "Synchronisation terminee avec succes"
        echo "=========================================="
        exit 0
    fi

    echo "Echec tentative $TRY - Code retour rsync : $RC" | tee -a "$LOGFILE"

    TRY=$((TRY + 1))

    if [ $TRY -le $MAX_RETRY ]; then
        echo "Nouvelle tentative dans $WAIT_SECONDS secondes..." | tee -a "$LOGFILE"
        sleep $WAIT_SECONDS
    fi
done

# =====================================================
# ECHEC FINAL
# =====================================================

echo "" | tee -a "$LOGFILE"
echo "ERREUR lors de la synchronisation" | tee -a "$LOGFILE"
echo "Code retour final rsync : $RC" | tee -a "$LOGFILE"

echo "=========================================="
echo "ECHEC DE LA SYNCHRONISATION"
echo "Voir le log : $LOGFILE"
echo "=========================================="

exit $RC